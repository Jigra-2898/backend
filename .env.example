PORT=4000
JWT_SECRET=your_jwt_secret_here
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password123
STAFF_EMAIL=staff@example.com
STAFF_PASSWORD=password123
# Set this to your Vercel URL on production (e.g., https://backend-domain.vercel.app) - NO trailing slash
API_BASE_URL=https://backend-livid-phi-92.vercel.app
# Frontend URLs for CORS (comma-separated, optional - all *.vercel.app accepted by default)
FRONTEND_URLS=https://frontend-xxxxx.vercel.app,http://localhost:3000

# Vercel Blob Storage (for serverless image hosting without size limits)
# Get token from Vercel Dashboard > Settings > Storage > Blob > Create Database
# Required for upload_to_blob.js script
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx_your_token_here
