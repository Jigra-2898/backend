{
  "version": 2,
  "buildCommand": "npm install",
  "installCommand": "npm ci --omit=dev",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "index.js": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "db.json"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}
